        self.simulation_mode = simulation_mode
        
        # Load Network Configuration (Single Source of Truth)
        self.networks = self.config.get_configured_networks()
        self.w3_connections: Dict[str, Web3] = {}
        self.circuit_breakers: Dict[str, CircuitBreaker] = {}
        self.gas_caches: Dict[str, GasPriceCache] = {}
        self.current_rpc_indices: Dict[str, int] = {}  # Track primary vs backup RPC
        
        # Initialize Networks
        self._initialize_node()
        
        # =====================================================
        # Nonce Management
