class ReceiptTracker:
    """
    Tracks pending transaction receipts with monitoring.
    Handles re-broadcast logic for stuck transactions.
    """
    
    def __init__(self, executor_w3_connections: Dict[str, Web3]):
        self.w3_connections = executor_w3_connections
        self.pending_txs: Dict[str, Dict[str, Any]] = {}
        self.lock = threading.Lock()
        
        # Start background monitor
        self._monitor_thread = None
        self._running = False

    def add_pending(self, tx_hash: str, network_name: str, tx_data: Dict[str, Any]):
        """Add a pending transaction to track."""
        with self.lock:
            self.pending_txs[tx_hash] = {
                "network": network_name,
                "tx_hash": tx_hash,
                "submitted_at": datetime.now(),
                "attempts": 1,
                "last_attempt_at": datetime.now(),
                "data": tx_data
            }

    def remove_pending(self, tx_hash: str):
        """Remove a transaction from pending tracking."""
        with self.lock:
            self.pending_txs.pop(tx_hash, None)

    def get_receipt(self, tx_hash: str, timeout: int = 120) -> Optional[Dict[str, Any]]:
        """Wait for transaction receipt with timeout."""
        # Extract network from pending or hash
        with self.lock:
            pending = self.pending_txs.get(tx_hash)
            network_name = pending["network"] if pending else None
        
        if not network_name:
            return None
        
        w3 = self.w3_connections.get(network_name)
        if not w3:
            return None
        
        try:
            receipt = w3.eth.wait_for_transaction_receipt(
                tx_hash,
                timeout=timeout,
                poll_latency=1.0
            )
            
            return {
                "status": "success" if receipt['status'] == 1 else "failed",
                "block_number": receipt['blockNumber'],
                "gas_used": receipt['gasUsed'],
                "effective_gas_price": receipt.get('effectiveGasPrice', 0),
                "tx_hash": tx_hash
            }
        except TimeExhausted:
            logger.warning(f"⏱️ Transaction receipt timeout for {tx_hash}")
            return None
        except TransactionNotFound:
            logger.warning(f"🔍 Transaction not found for {tx_hash}")
            return None
        except Exception as e:
            logger.error(f"❌ Error getting receipt for {tx_hash}: {e}")
            return None

    def start_monitor(self, check_interval: int = 30):
        """Start background monitoring thread."""
        if self._running:
            return
        
        self._running = True
        self._monitor_thread = threading.Thread(
            target=self._monitor_loop,
            args=(check_interval,),
            daemon=True
        )
        self._monitor_thread.start()
        logger.info("🔍 Receipt monitoring thread started")

    def stop_monitor(self):
        """Stop background monitoring thread."""
        self._running = False
        if self._monitor_thread:
            self._monitor_thread.join(timeout=5)
        logger.info("🔍 Receipt monitoring thread stopped")

    def _monitor_loop(self, check_interval: int):
        """Background monitoring loop for pending transactions."""
        while self._running:
            time.sleep(check_interval)
            
            check_cutoff = datetime.now() - timedelta(minutes=5)
            
            with self.lock:
                pending_txs = list(self.pending_txs.items())
            
            for tx_hash, tx_info in pending_txs:
                # Check if transaction is stuck (5+ minutes with no receipt)
                if tx_info["submitted_at"] < check_cutoff:
                    network_name = tx_info["network"]
                    w3 = self.w3_connections.get(network_name)
                    
                    if not w3:
                        continue
                    
                    try:
                        # Check if mined
                        receipt = w3.eth.get_transaction_receipt(tx_hash)
                        
                        if receipt:
                            # Transaction was mined, remove from pending
                            logger.info(f"✅ Transaction {tx_hash} mined at block {receipt['blockNumber']}")
                            with self.lock:
                                self.pending_txs.pop(tx_hash, None)
                        else:
                            # Still pending, consider re-broadcast
                            tx_info["attempts"] += 1
                            
                            if tx_info["attempts"] <= 3:
                                logger.info(
                                    f"🔄 Re-broadcasting transaction {tx_hash} "
                                    f"(attempt {tx_info['attempts']}/3)"
                                )
                                # Re-broadcast would happen here
                                tx_info["last_attempt_at"] = datetime.now()
                            else:
                                logger.error(
                                    f"❌ Transaction {tx_hash} stuck after 3 re-broadcast attempts. "
                                    f"Manual review required."
                                )
                                with self.lock:
                                    self.pending_txs.pop(tx_hash, None)
                    
                    except Exception as e:
                        logger.error(f"❌ Error monitoring transaction {tx_hash}: {e}")


