ALCHEMY_API_KEY=PaFeaQHOIM70xNZgHYqdU

# ┌─────────────────────────────────────────────────────────────────────┐
# │ Primary Network: OP Mainnet (Optimism L2)                             │
# └─────────────────────────────────────────────────────────────────────┘
