ALCHEMY_OP_MAINNET_ENDPOINT=https://opt-mainnet.g.alchemy.com/v2/PaFeaQHOIM70xNZgHYqdU
ALCHEMY_OP_SEPOLIA_API_KEY=PaFeaQHOIM70xNZgHYqdU
ALCHEMY_OP_SEPOLIA_ENDPOINT=https://opt-sepolia.g.alchemy.com/v2/PaFeaQHOIM70xNZgHYqdU

# ┌─────────────────────────────────────────────────────────────────────┐
# │ Fallback Network: Ethereum Mainnet                                    │
# └─────────────────────────────────────────────────────────────────────┘
ALCHEMY_ETH_MAINNET_API_KEY=PaFeaQHOIM70xNZgHYqdU
ALCHEMY_ETH_MAINNET_ENDPOINT=https://eth-mainnet.g.alchemy.com/v2/PaFeaQHOIM70xNZgHYqdU
ALCHEMY_ETH_SEPOLIA_API_KEY=PaFeaQHOIM70xNZgHYqdU
