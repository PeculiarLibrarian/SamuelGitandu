# ┌─────────────────────────────────────────────────────────────────────┐
# │ Network Selection                                                     │
# └─────────────────────────────────────────────────────────────────────┘
PADI_PRIMARY_NETWORK=op
PADI_FALLBACK_NETWORKS=ethereum

# ┌─────────────────────────────────────────────────────────────────────┐
# │ PADI Bureau Configuration                                             │
# └─────────────────────────────────────────────────────────────────────┘
PADI_NODE_LOCATION=Nairobi-01
PADI_DEFAULT_NETWORK=mainnet
PADI_MAX_DRIFT_SECONDS=5
PADI_BLOCK_REFRESH_INTERVAL=15
PADI_LOG_LEVEL=INFO
PADI_DETAILED_LOGS=false

# ┌─────────────────────────────────────────────────────────────────────┐
# │ 1003 Rule Enforcement (Nairobi-01 Node Critical Configuration)       │
# │ DO NOT MODIFY WITHOUT ARCHITECT APPROVAL                              │
# └─────────────────────────────────────────────────────────────────────┘
PADI_CONFIDENCE_THRESHOLD=1.0
PADI_REQUIRED_VERIFICATION_SOURCES=3
