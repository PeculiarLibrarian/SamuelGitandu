# =====================================================
# 🏛️ PADI BUREAU — NAIROBI NODE-01
# PHASE TWO: NERVOUS SYSTEM CONFIGURATION
# =====================================================

# --- BLOCKCHAIN / BASE L2 CONFIG ---
# RPC endpoint from Alchemy, Infura, QuickNode, etc.
BASE_L2_RPC_URL=https://your_rpc_url_here

# Optional wallet credentials for signing/execution (Phase 3)
# NEVER commit real private keys to GitHub
# PADI_WALLET_ADDRESS=0xYourWalletAddress
# PADI_PRIVATE_KEY=YourPrivateKeyHere

# --- NODE IDENTITY & LOGGING ---
NODE_ID=NAIROBI-NODE-01
LOG_LEVEL=INFO        # INFO / DEBUG / WARNING
DEBUG=True            # Toggle detailed debug logs (development)

# --- SEMANTIC ENGINE PATHS ---
ONTOLOGY_PATH=schema/ontology.ttl
SHAPES_PATH=schema/shapes.ttl

# --- OPTIONAL BATCH / PROCESSING PARAMETERS ---
BATCH_SIZE=50         # Number of signals to process in batch
