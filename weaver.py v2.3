    def _process_network_batch(
        self,
        network_type: str,
        signals: List[Dict[str, Any]],
        return_rejected_details: bool
    ) -> Tuple[List[Union[Graph, Dict[str, Any]]], List[Dict[str, Any]]]:
        """
        Process a batch of signals for a specific network.
        🚀 v2.3 NEW: Separated for concurrent execution.
        
        Args:
            network_type: Network type to process
            signals: List of signals for this network
            return_rejected_details: Return rejection details as dict
        
        Returns:
            Tuple of (results, rejected_list)
        """
        results = []
        rejected = []
        
        logger.info(f"🚀 Processing {len(signals)} signals on {network_type}")
        
        for sig in signals:
            graph = self.process_signal(sig, network_type, return_rejected_details=return_rejected_details)
            
            if graph is None and return_rejected_details:
                # graph is a rejection dict when return_rejected_details=True
                if isinstance(graph, dict) and graph.get("status") == "rejected":
                    rejected.append(graph)
            elif graph is not None:
                results.append(graph)
        
        # Update concurrent stats
        self._concurrent_stats["total_network_groups_processed"] += 1
        
        logger.info(
            f"✅ {network_type}: {len(results)} promoted, {len(rejected)} rejected "
            f"(Total: {len(signals)})"
        )
        
        return results, rejected

    def process_batch(
        self,
        signals: List[Dict[str, Any]],
        return_rejected: bool = False,
        use_concurrent: bool = True  # 🚀 v2.3 NEW: Enable/disable concurrent processing
    ) -> Union[List[Graph], Tuple[List[Graph], List[Dict[str, Any]]]]:
        """
        Process multiple signals in a deterministic batch with optional concurrent processing.
        🚀 v2.3 NEW: Concurrent processing for improved performance.
        
        Args:
            signals: List of signal data dictionaries
            return_rejected: Return rejected signals with details (default: False)
            use_concurrent: Enable concurrent network processing (default: True)
        
        Returns:
            List of RDF graphs for promoted ExecutableFacts,
            or tuple of (promoted_graphs, rejected_signals) if return_rejected=True
        """
        batch_start_time = time.time()
        
        print(f"\n--- 🔄 Weaver: Processing batch of {len(signals)} signals ---")
        logger.info(f"Processing batch of {len(signals)} signals")
        
        # Store original order for deterministic results
        original_order = [(idx, sig.get("uid", ""), sig.get("label", "")) 
                         for idx, sig in enumerate(signals)]
        
        results = []
        rejected = []
        
        # Group signals by network for efficient processing
        signals_by_network: Dict[str, List[Dict[str, Any]]] = {}
        for sig in signals:
            network_type = sig.get("network_type", self.config.DEFAULT_NETWORK_TYPE)
            if network_type not in signals_by_network:
                signals_by_network[network_type] = []
            signals_by_network[network_type].append(sig)
        
        # 🚀 v2.3 NEW: Concurrent Processing
        if use_concurrent and self.max_workers > 1 and len(signals_by_network) > 1:
            print(f"🚀 Using concurrent processing with {self.max_workers} threads")
            logger.info(f"🚀 Concurrent processing enabled: {self.max_workers} workers")
            
            with ThreadPoolExecutor(max_workers=self.max_workers) as executor:
                # Submit all network batches for concurrent processing
                future_to_network = {
                    executor.submit(
                        self._process_network_batch,
                        network_type,
                        network_signals,
                        return_rejected
                    ): network_type
                    for network_type, network_signals in signals_by_network.items()
                }
                
                # Collect results as they complete
                for future in as_completed(future_to_network):
                    network_type = future_to_network[future]
                    try:
                        network_results, network_rejected = future.result()
                        results.extend(network_results)
                        if return_rejected:
                            rejected.extend(network_rejected)
                    except Exception as e:
                        logger.error(
                            f"❌ Error processing batch for {network_type}: {e}"
                        )
        
        else:
            # Sequential processing (fallback)
            print("📡 Using sequential processing")
            logger.info("📡 Sequential processing enabled")
            
            for network_type, network_signals in signals_by_network.items():
                print(f"\n--- 🔄 Processing {len(network_signals)} signals on {network_type} ---")
                logger.info(f"Processing {len(network_signals)} signals on {network_type}")
                
                network_results, network_rejected = self._process_network_batch(
                    network_type,
                    network_signals,
                    return_rejected
                )
                results.extend(network_results)
                if return_rejected:
                    rejected.extend(network_rejected)
        
        # 🚀 v2.3 NEW: Sort results to maintain deterministic order
        if original_order:
            results.sort(
                key=lambda g: self._find_graph_index(g, original_order)
            )
        
        promoted_count = len(results)
        total_count = len(signals)
        rejected_count = len(rejected) if return_rejected else (total_count - promoted_count)
        
        completion_msg = (
            f"\n✅ Batch complete: {promoted_count}/{total_count} signals promoted, "
            f"{rejected_count} rejected."
        )
        logger.info(completion_msg)
        print(completion_msg)
        
        # 🛡️ v2.2: Display detailed breakdown by network
        for network_type, network_signals in signals_by_network.items():
            network_stats = self._stats["network_stats"].get(network_type, {})
            network_promoted = network_stats.get("promoted", 0)
            network_rejected = network_stats.get("rejected", 0)
            network_total = network_stats.get("total", len(network_signals))
            network_msg = (
                f"   {network_type}: {network_promoted}/{network_total} promoted, "
                f"{network_rejected} rejected"
            )
            logger.info(network_msg)
            print(network_msg)
        
        # 🛡️ v2.2: Log batch statistics
        self._log_batch_statistics()
        
        # 🚀 v2.3 NEW: Update concurrent processing stats
        batch_time = time.time() - batch_start_time
        self._concurrent_stats["total_batches_processed"] += 1
        self._concurrent_stats["total_processing_time"] += batch_time
        self._concurrent_stats["min_batch_processing_time"] = min(
            self._concurrent_stats["min_batch_processing_time"],
            batch_time
        )
        self._concurrent_stats["max_batch_processing_time"] = max(
            self._concurrent_stats["max_batch_processing_time"],
            batch_time
        )
        self._concurrent_stats["avg_batch_processing_time"] = (
            self._concurrent_stats["total_processing_time"] /
            self._concurrent_stats["total_batches_processed"]
        )
        
        logger.info(
            f"⏱️ Batch processing time: {batch_time:.3f}s "
            f"(Avg: {self._concurrent_stats['avg_batch_processing_time']:.3f}s)"
        )
        
        if return_rejected:
            return results, rejected
        else:
            return results

    def _find_graph_index(
        self,
        graph: Union[Graph, Dict[str, Any]],
        original_order: List[Tuple[int, str, str]]
    ) -> int:
        """
        Find the original index of a graph for deterministic sorting.
        🚀 v2.3 NEW HELPER METHOD.
        
        Args:
            graph: RDF graph or rejection dict
            original_order: List of (index, uid, label) tuples
        
        Returns:
            Original index position (defaults to end if not found)
        """
        if isinstance(graph, Dict) and graph.get("status") == "rejected":
            # It's a rejection dict
            signal_id = graph.get("signal_id", "")
            for idx, uid, label in original_order:
                if uid == signal_id:
                    return idx
        else:
            # It's an RDF graph
            for idx, uid, label in original_order:
                # Try to match by checking graph for signal ID
                try:
                    signal_id_values = graph.value(
                        EX[label.split("_")[0] if "_" in label else label],
                        EX.hasSignalID
                    )
                    if signal_id_values and str(signal_id_values) == uid:
                        return idx
                except:
                    pass
        
        # Default to end if not found
        return len(original_order)

    def _log_batch_statistics(self):
        """
        Log current batch statistics.
        🛡️ v2.2 HELPER METHOD.
        """
        logger.info("📊 Batch Statistics:")
        logger.info(f"   Total Signals Processed: {self._stats['total_signals_processed']}")
        logger.info(f"   Total Promoted: {self._stats['total_promoted']}")
        logger.info(f"   Total Rejected: {self._stats['total_rejected']}")
        
        for network, stats in self._stats["network_stats"].items():
            logger.info(
                f"   {network}: {stats['promoted']} promoted, "
                f"{stats['rejected']} rejected "
                f"(Total: {stats['total']})"
            )
        
        # 🚀 v2.3 NEW: Log concurrent processing statistics
        if self._concurrent_stats["total_batches_processed"] > 0:
            logger.info(
                f"   Avg Batch Time: "
                f"{self._concurrent_stats['avg_batch_processing_time']:.3f}s"
            )
            logger.info(
                f"   Max Batch Time: "
                f"{self._concurrent_stats['max_batch_processing_time']:.3f}s"
            )
            logger.info(
                f"   Min Batch Time: "
                f"{self._concurrent_stats['min_batch_processing_time']:.3f}s"
            )

    def get_connected_networks(self) -> List[str]:
        """Get list of connected network types."""
        return list(self.w3_connections.keys())

    def get_network_status(self) -> Dict[str, Dict[str, str]]:
        """Get connection status for all configured networks."""
        status = {}
        configured_networks = self.config.get_configured_networks()
        
        for network_type, config in configured_networks.items():
            w3 = self.w3_connections.get(network_type)
            status[network_type] = {
                "name": config["name"],
                "chain_id": config["chain_id"],
                "connected": w3 is not None,
                "rpc_url": config["rpc_url"]
            }
        
        return status

    def get_statistics(self) -> Dict[str, Any]:
        """
        Get current processing statistics.
        🛡️ v2.2 HELPER METHOD.
        
        Returns:
            Dictionary with processing statistics
        """
        return {
            **self._stats,
            "promoted_rate": (
                self._stats["total_promoted"] / self._stats["total_signals_processed"]
                if self._stats["total_signals_processed"] > 0
                else 0.0
            ),
            "rejection_rate": (
                self._stats["total_rejected"] / self._stats["total_signals_processed"]
                if self._stats["total_signals_processed"] > 0
                else 0.0
            ),
            "concurrent_stats": self._concurrent_stats  # 🚀 v2.3 NEW
        }

    def get_diagnostics(self) -> Dict[str, Any]:
        """Get comprehensive diagnostics."""
        return {
            "node_id": self.node_id,
            "timestamp": datetime.now().isoformat(),
            "connected_networks": self.get_connected_networks(),
            "network_status": self.get_network_status(),
            "max_workers": self.max_workers,  # 🚀 v2.3 NEW
            "parallel_processing_enabled": self.max_workers > 1,  # 🚀 v2.3 NEW
            "statistics": self.get_statistics(),
            "config_diagnostics": self.config.get_diagnostics()
        }


