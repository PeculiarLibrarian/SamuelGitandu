    def __init__(
        self,
        max_workers: Optional[int] = None  # 🚀 v2.3 NEW: Configurable thread pool size
    ):
        """
        Initialize Weaver with PadiConfig v5.1 singleton.
        
        Args:
            max_workers: Maximum number of worker threads for concurrent processing.
                        If None, uses number of configured networks.
        """
        # 🛡️ v2.1: Load PadiConfig singleton
        self.config = PadiConfig()
        
        # 🛡️ v2.1: Initialize with sovereign node identity
        self.node_id = self.config.node_id

        # 🛡️ v2.2: Cache network config for performance
        self._network_config_cache: Dict[str, Dict[str, Any]] = {}

        # 🚀 v2.3 NEW: Configure thread pool size
        configured_networks = self.config.get_configured_networks()
        self.max_workers = max_workers or len(configured_networks)

        # Initialize multi-network nervous system
        self.w3_connections: Dict[str, Web3] = {}
        self._initialize_networks()
        
        # 🛡️ v2.2: Initialize statistics tracking
        self._stats = {
            "total_signals_processed": 0,
            "total_promoted": 0,
            "total_rejected": 0,
            "network_stats": {}
        }
        
        # 🚀 v2.3 NEW: Concurrent processing statistics
        self._concurrent_stats = {
            "total_batches_processed": 0,
            "total_network_groups_processed": 0,
            "parallel_processing_enabled": self.max_workers > 1,
            "avg_batch_processing_time": 0.0,
            "max_batch_processing_time": 0.0,
            "min_batch_processing_time": float('inf'),
            "total_processing_time": 0.0
        }

    def _initialize_networks(self):
        """Initialize Web3 connections using PadiConfig singleton."""
        # 🛡️ v2.1: Pull validated networks from singleton
        configured_networks = self.config.get_configured_networks()
        
        if not configured_networks:
            raise ConnectionError(f"❌ {self.node_id}: No networks configured.")
        
        logger.info(f"{self.node_id}: Initializing {len(configured_networks)} networks...")
        
        for name, net_cfg in configured_networks.items():
            try:
                w3 = Web3(Web3.HTTPProvider(net_cfg["rpc_url"]))
                if w3.is_connected():
                    self.w3_connections[name] = w3
                    connection_msg = (
                        f"🚀 {self.node_id}: Connected to {net_cfg['name']} "
                        f"(ID: {net_cfg['chain_id']})"
                    )
                    logger.info(connection_msg)
                    print(connection_msg)
                else:
                    warning_msg = f"⚠️ {self.node_id}: Connection failed for {net_cfg['name']}"
                    logger.warning(warning_msg)
                    print(warning_msg)
            except Exception as e:
                error_msg = f"❌ {self.node_id}: Error on {name}: {e}"
                logger.error(error_msg)
                print(error_msg)

        if not self.w3_connections:
            raise ConnectionError(
                f"❌ {self.node_id}: No networks connected. "
                "Weaver cannot process signals."
            )
        
        # 🚀 v2.3 NEW: Log concurrent processing configuration
        if self.max_workers > 1:
            logger.info(
                f"🚀 Concurrent processing enabled: "
                f"{self.max_workers} worker threads"
            )
            print(
                f"🚀 Concurrent processing enabled: "
                f"{self.max_workers} worker threads"
            )
        else:
            logger.info("📡 Sequential processing enabled (1 worker thread)")
            print("📡 Sequential processing enabled (1 worker thread)")

    def get_network_config_cached(self, network_type: str) -> Dict[str, Any]:
        """
        Get network configuration from cache.
        🛡️ v2.2: Improve performance by caching network config.
        
        Args:
            network_type: Network type string
        
        Returns:
            Dictionary with network configuration
        """
        if network_type not in self._network_config_cache:
            self._network_config_cache[network_type] = self.config.get_network_config(network_type)
        return self._network_config_cache[network_type]

    def _pre_flight_registry_handshake(
        self,
        action: str,
        target: str,
        network: str
    ) -> Tuple[bool, Optional[str]]:
        """
        🛡️ v2.1: PRE-FLIGHT REGISTRY HANDSHAKE
        Verifies the action ontology before the signal hits the Audit phase.
        """
        # Step 1: Validate against PadiConfig Registry
        is_valid, error = self.config.verify_action_ontology(action, target)
        if not is_valid:
            return False, error
        
        # Step 2: Ensure network alignment
        if network not in self.w3_connections:
            return False, f"Network {network} is not active on Node {self.node_id}"
            
        return True, None

    def get_live_context(
        self,
        network_type: str,
        use_cache: bool = False
    ) -> Optional[Dict[str, Any]]:
        """
        Fetch latest block and gas price from specified network.
        🛡️ v2.1: Uses blockchain timestamp (synchronizes across nodes).
        🛡️ v2.2: Optional caching for improved performance.
        
        Args:
            network_type: Network type string
            use_cache: Use cached context if available (default: False)
        
        Returns:
            Dictionary with block number, gas price, timestamp, or None if error
        """
        # Validate network configuration
        if network_type not in self.w3_connections:
            logger.error(f"❌ Network {network_type} not connected. Cannot fetch context.")
            return None
        
        w3 = self.w3_connections[network_type]
        
        try:
            # ✅ Get full block details (more accurate than w3.eth.block_number)
            latest_block = w3.eth.get_block('latest')
            gas_price = w3.from_wei(w3.eth.gas_price, 'gwei')
            
            context = {
                "block_number": latest_block['number'],
                "gas_price": float(gas_price),
                # ✅ Use blockchain timestamp (synchronizes across nodes)
                "timestamp": datetime.fromtimestamp(latest_block['timestamp']).isoformat(),
                "network_type": network_type
            }
            
            # 🛡️ v2.2: Cache context if requested
            if use_cache:
                if not hasattr(self, '_context_cache'):
                    self._context_cache = {}
                self._context_cache[network_type] = context
            
            return context
        except Exception as e:
            logger.error(f"📡 RPC Sync Error on {network_type}: {e}")
            # 🛡️ v2.2: Try to return cached context if available
            if use_cache and hasattr(self, '_context_cache') and network_type in self._context_cache:
                logger.warning(f"📡 Using cached context for {network_type}")
                return self._context_cache[network_type]
            return None

    def process_signal(
        self,
        raw_data: Dict[str, Any],
        network_type: Optional[str] = None,
        return_rejected_details: bool = False
    ) -> Union[Optional[Graph], Optional[Dict[str, Any]]]:
        """
        Process signal with Pre-flight Handshake and Sovereign Alignment.
        🛡️ v2.2: Optionally return rejected details with reason.
        
        Args:
            raw_data: Signal data dictionary
            network_type: Network type (optional, inferred from signal or config)
            return_rejected_details: Return rejection details as dict (default: False)
        
        Returns:
            RDF Graph if promoted, None if rejected, or rejection dict if return_rejected_details=True
        """
        # 🛡️ v2.2: Track signal rejection reason
        rejection_reason = None
        
        # Infer network using singleton defaults
        network_type = network_type or raw_data.get(
            "network_type",
            self.config.DEFAULT_NETWORK_TYPE
        )
        
        # 🛡️ v2.1: Execute Pre-flight Handshake
        is_valid, error_msg = self._pre_flight_registry_handshake(
            raw_data.get("action", "OBSERVE"),
            raw_data.get("target", "0x000"),
            network_type
        )
        
        if not is_valid:
            rejection_reason = f"Handshake Rejected: {error_msg}"
            logger.error(f"❌ Handshake Rejected: {error_msg}")
            print(f"❌ Handshake Rejected: {error_msg}")
            
            # 🛡️ v2.2: Track rejection stats
            self._reject_signal(raw_data, network_type, rejection_reason)
            
            # 🛡️ v2.2: Return rejection details if requested
            if return_rejected_details:
                return self._create_rejection_detail(
                    raw_data,
                    network_type,
                    "handshake_rejected",
                    rejection_reason
                )
            return None

        # Fetch Live Context
        ctx = self.get_live_context(network_type)
        if not ctx:
            rejection_reason = f"Infrastructure Desync on {network_type}"
            safety_msg = (
                f"🛡️ Safety Lock: Signal rejected due to "
                f"Infrastructure Desync on {network_type}."
            )
            logger.warning(safety_msg)
            print(safety_msg)
            
            # 🛡️ v2.2: Track rejection stats
            self._reject_signal(raw_data, network_type, rejection_reason)
            
            # 🛡️ v2.2: Return rejection details if requested
            if return_rejected_details:
                return self._create_rejection_detail(
                    raw_data,
                    network_type,
                    "infrastructure_desync",
                    rejection_reason
                )
            return None

        print(
            f"\n--- 🧵 Weaving Signal: {raw_data.get('label', 'Unknown')} "
            f"({network_type}) ---"
        )
        
        # 🛡️ v2.2: Use cached network config
        net_cfg = self.get_network_config_cached(network_type)
        
        # 🛡️ v2.1: Trigger Audit via bureau_core
        graph, conforms, status, report = audit_signal(
            name=raw_data.get("label", "UNLABELED_SIG"),
            confidence=raw_data.get("confidence", 0.0),
            sources=raw_data.get("sources", []),
            target_address=raw_data.get("target"),
            action_type=raw_data.get("action"),
            network_type=network_type,
            chain_id=net_cfg["chain_id"],
            block_number=ctx["block_number"],
            # 🛡️ Pass 1003 Rule enforcement toggle from config
            enforce_1003=self.config.validation_rules.get("enforce_1003_rule", True)
        )

        # Reporting
        if conforms:
            success_msg = (
                f"✅ DETERMINISTIC: Signal {raw_data.get('uid')} promoted.\n"
                f"📍 Target: {raw_data.get('target')} | Network: {network_type} "
                f"| Block: {ctx['block_number']}"
            )
            logger.info(success_msg)
            print(success_msg)
            
            # 🛡️ v2.2: Track promotion stats
            self._promote_signal(raw_data, network_type)
            
            return graph
        else:
            rejection_reason = f"Validation Block: {report}"
            failure_msg = f"❌ PROBABILISTIC: Signal blocked. Reason: {report}"
            logger.warning(failure_msg)
            print(failure_msg)
            
            # 🛡️ v2.2: Track rejection stats
            self._reject_signal(raw_data, network_type, rejection_reason)
            
            # 🛡️ v2.2: Return rejection details if requested
            if return_rejected_details:
                return self._create_rejection_detail(
                    raw_data,
                    network_type,
                    "validation_block",
                    rejection_reason
                )
            return None

    def _create_rejection_detail(
        self,
        signal: Dict[str, Any],
        network_type: str,
        rejection_type: str,
        reason: str
    ) -> Dict[str, Any]:
        """
        Create a detailed rejection record.
        🛡️ v2.2 HELPER METHOD.
        
        Args:
            signal: Signal data dictionary
            network_type: Network type
            rejection_type: Type of rejection (handshake, infrastructure, validation)
            reason: Detailed reason for rejection
        
        Returns:
            Dictionary with rejection details
        """
        return {
            "status": "rejected",
            "rejection_type": rejection_type,
            "reason": reason,
            "signal_id": signal.get("uid"),
            "label": signal.get("label"),
            "network": network_type,
            "action": signal.get("action"),
            "target": signal.get("target"),
            "confidence": signal.get("confidence"),
            "timestamp": datetime.now().isoformat()
        }

    def _promote_signal(self, signal: Dict[str, Any], network_type: str):
        """
        Track signal promotion statistics.
        🛡️ v2.2 HELPER METHOD.
        
        Args:
            signal: Signal data dictionary
            network_type: Network type
        """
        self._stats["total_signals_processed"] += 1
        self._stats["total_promoted"] += 1
        
        if network_type not in self._stats["network_stats"]:
            self._stats["network_stats"][network_type] = {
                "total": 0,
                "promoted": 0,
                "rejected": 0
            }
        
        self._stats["network_stats"][network_type]["total"] += 1
        self._stats["network_stats"][network_type]["promoted"] += 1

    def _reject_signal(self, signal: Dict[str, Any], network_type: str, reason: str):
        """
        Track signal rejection statistics.
        🛡️ v2.2 HELPER METHOD.
        
        Args:
            signal: Signal data dictionary
            network_type: Network type
            reason: Rejection reason
        """
        self._stats["total_signals_processed"] += 1
        self._stats["total_rejected"] += 1
        
        if network_type not in self._stats["network_stats"]:
            self._stats["network_stats"][network_type] = {
                "total": 0,
                "promoted": 0,
                "rejected": 0
            }
        
        self._stats["network_stats"][network_type]["total"] += 1
        self._stats["network_stats"][network_type]["rejected"] += 1
        
        # Log rejection with details
        logger.info(
            f"📊 Signal Rejected: ID={signal.get('uid')}, "
            f"Network={network_type}, Reason={reason}"
        )

    # =====================================================
    # 🚀 v2.3 NEW: CONCURRENT NETWORK PROCESSING
