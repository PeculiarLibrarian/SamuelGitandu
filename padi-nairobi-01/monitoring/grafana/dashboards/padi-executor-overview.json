  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": ["padi"],
      "targetBlank": true,
      "title": "PADI Documentation",
      "tooltip": "Sovereign Source of Truth",
      "type": "dashboards",
      "url": "https://docs.asi1.ai"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "The 'Weakest Link' monitor. If any single node drops, this grid reflects the systemic vulnerability.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "index": 0, "text": "DOWN" },
                "1": { "color": "green", "index": 1, "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "up{job=\"padi-executor\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "title": "Node Status Grid (Weakest Link)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Calculated relative TVL health against the Bureau target.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 150,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "green", "value": 100 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true
      },
      "targets": [
        { "expr": "((padi_bureau_tvl_usd{node=\"$node\"} / padi_bureau_target_tvl_usd{node=\"$node\"}) * 100) or vector(0)", "instant": true, "refId": "A" }
      ],
      "title": "TVL % of Target",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Slashing risk detection - missed blocks for validator downtime",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "green", "index": 0, "text": "SAFE" } },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "id": 14,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": false
      },
      "targets": [
        { "expr": "padi_executor_missed_blocks{node=\"$node\"}", "instant": true, "legendFormat": "Missed Blocks", "refId": "A" }
      ],
      "title": "Slashing Risk",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Structural integrity verification against PADI SHACL shapes.",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [
            {
              "options": {
                "0": { "color": "green", "index": 0, "text": "VALID" },
                "1": { "color": "red", "index": 1, "text": "VIOLATION" }
              },
              "type": "value"
            }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "PASS", "color": "green" },
                      "1": { "text": "FAIL", "color": "red" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 15,
      "options": { "showHeader": true },
      "targets": [
        { "expr": "padi_shacl_validation_status{node=\"$node\"}", "legendFormat": "Status", "refId": "A" }
      ],
      "title": "SHACL Structural Validation",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Throughput monitoring with corrected calc logic. All rate calculations use 1-min windows for high-resolution spike detection.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "sum(rate(padi_executor_jobs_completed_total{node=\"$node\"}[1m]))", "refId": "A" }
      ],
      "title": "Job Throughput",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Executor CPU using regex name matching to prevent container ID fragmentation.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": true
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 14 },
      "id": 9,
      "options": {
        "legend": {
          "calcs": ["last", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"padi-executor.*\"}[1m])) * 100", "legendFormat": "Executor CPU %", "refId": "A" }
      ],
      "title": "Resource Consumption: CPU",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Executor service memory usage using regex name matching.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 2147483648 }
            ]
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 14 },
      "id": 10,
      "options": {
        "legend": {
          "calcs": ["last", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        { "expr": "sum(container_memory_usage_bytes{name=~\"padi-executor.*\"})", "legendFormat": "Memory Usage", "refId": "A" },
        { "expr": "sum(container_memory_working_set_bytes{name=~\"padi-executor.*\"})", "legendFormat": "Working Set", "refId": "B" }
      ],
      "title": "Resource Consumption: Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "RPC health status from healthcheck sidecar. Immediate alert if RPC freezes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "index": 0, "text": "UNHEALTHY" },
                "1": { "color": "green", "index": 1, "text": "HEALTHY" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 20 },
      "id": 12,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": false
      },
      "targets": [
        { "expr": "padi_node_rpc_health{node=\"$node\"}", "instant": true, "legendFormat": "RPC Health", "refId": "A" }
      ],
      "title": "RPC Health",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Job queue depth - critical for detecting backpressure.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 20 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "padi_executor_jobs_queued{node=\"$node\"}", "instant": true, "legendFormat": "Queued", "refId": "A" }
      ],
      "title": "Jobs Queued",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Transaction validation rate by chain (1-min window).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "tps"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "id": 11,
      "options": {
        "legend": {
          "calcs": ["last", "sum"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        { "expr": "sum(rate(padi_executor_transactions_validated_total{node=\"$node\"}[1m])) by (chain_id)", "refId": "A", "legendFormat": "Chain {{chain_id}}" }
      ],
      "title": "Transaction Validation Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
