{{ define "email.subject" }}[PADI-Nairobi-01] {{ .Status | toUpper }}{{ if eq .Status "firing" }}: {{ (index .Alerts.Firing 0).Labels.alertname }}{{ if gt (len .Alerts.Firing) 1 }} (+{{ sub (len .Alerts.Firing) 1 }}){{ end }}{{ end }}{{ end }}

{{ define "email.default.subject" }}[PADI-Nairobi-01] {{ .Status | toUpper }}{{ end }}

{{ define "email.plain.html" }}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Segoe UI', Helvetica, Arial, sans-serif; line-height: 1.6; color: #333; background-color: #f9f9f9; padding: 20px; }
        .container { max-width: 700px; margin: 0 auto; background: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; }
        .header { background: linear-gradient(135deg, #1a237e 0%, #283593 100%); color: #ffffff; padding: 25px; text-align: center; border-bottom: 4px solid #c6a700; }
        .status-bar { padding: 10px 25px; font-weight: bold; text-align: center; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; }
        .firing { background-color: #ffebee; color: #c62828; }
        .resolved { background-color: #e8f5e9; color: #2e7d32; }
        .alert-box { margin: 20px; padding: 15px; border-radius: 6px; border-left: 5px solid #ccc; background-color: #fafafa; }
        .critical { border-left-color: #d32f2f; background-color: #fff5f5; }
        .warning { border-left-color: #ffa000; background-color: #fffdf2; }
        .info { border-left-color: #1976d2; background-color: #f0f7ff; }
        .label { font-weight: bold; color: #555; width: 100px; display: inline-block; font-size: 12px; }
        .value { color: #111; font-size: 13px; font-family: 'Consolas', monospace; }
        .footer { background: #f1f1f1; padding: 15px; text-align: center; font-size: 11px; color: #777; border-top: 1px solid #e0e0e0; }
        a { color: #1a237e; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1 style="margin:0; font-size: 22px;">🏛️ PADI SOVEREIGN BUREAU</h1>
            <p style="margin:5px 0 0; opacity: 0.8;">Nairobi Node-01 — Production Observatory</p>
        </div>

        <div class="status-bar {{ if eq .Status "firing" }}firing{{ else }}resolved{{ end }}">
            {{ if eq .Status "firing" }}🚨 {{ .Alerts.Firing | len }} ACTIVE ALERTS{{ else }}✅ SYSTEM RECOVERED{{ end }}
        </div>

        {{ range .Alerts }}
        <div class="alert-box {{ if eq .Labels.severity "critical" }}critical{{ else if eq .Labels.severity "warning" }}warning{{ else }}info{{ end }}">
            <h3 style="margin-top:0; color: #111;">{{ if eq .Labels.severity "critical" }}🔴{{ else if eq .Labels.severity "warning" }}🟡{{ else }}🔵{{ end }} {{ .Labels.alertname }}</h3>
            
            <div style="margin-bottom: 5px;"><span class="label">STATUS:</span><span class="value">{{ toUpper .Status }}</span></div>
            <div style="margin-bottom: 5px;"><span class="label">SEVERITY:</span><span class="value">{{ toUpper .Labels.severity }}</span></div>
            
            {{ if .Labels.service }}<div style="margin-bottom: 5px;"><span class="label">SERVICE:</span><span class="value">{{ .Labels.service }}</span></div>{{ end }}
            {{ if .Labels.instance }}<div style="margin-bottom: 5px;"><span class="label">INSTANCE:</span><span class="value">{{ .Labels.instance }}</span></div>{{ end }}
            {{ if .Labels.blockchain }}<div style="margin-bottom: 5px;"><span class="label">CHAIN:</span><span class="value">{{ .Labels.blockchain }}</span></div>{{ end }}
            
            <hr style="border: 0; border-top: 1px solid #eee; margin: 10px 0;">
            
            {{ if .Annotations.summary }}<p style="font-size: 13px; font-weight: bold; margin-bottom: 5px;">{{ .Annotations.summary }}</p>{{ end }}
            {{ if .Annotations.description }}<p style="font-size: 12px; color: #444; margin-bottom: 10px;">{{ .Annotations.description }}</p>{{ end }}
            
            {{ if .ExternalURL }}
            <p style="margin-top: 10px;"><a href="{{ .ExternalURL }}">View in Prometheus</a></p>
            {{ end }}

            <p style="font-size: 10px; color: #999; margin-top: 10px;">Started: {{ .StartsAt.Format "2006-01-02 15:04:05 EAT" }}</p>
        </div>
        {{ end }}

        <div class="footer">
            <strong>PADI Protocol — Nairobi Bureau</strong><br>
            © 2026 Sovereign Systems | <a href="http://localhost:3000">Grafana Dashboard</a>
        </div>
    </div>
</body>
</html>
{{ end }}
