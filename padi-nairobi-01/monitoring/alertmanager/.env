# =====================================================
# Alertmanager Environment Variables — PADI Nairobi-01
# =====================================================
# Version: v2.2-PROD (corresponds with alertmanager_config.yml)
# Node: Nairobi-01
# Environment: Production
# Timezone: Africa/Nairobi
# Alchemy Integration: v1.0
# =====================================================

# =====================================================
# SMTP Configuration (Gmail)
# =====================================================
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_FROM=prometheus@padi-nairobi-01
SMTP_AUTH_USERNAME=your-email@gmail.com
SMTP_AUTH_PASSWORD=your-app-password

# =====================================================
# Slack Configuration
# =====================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =====================================================
# Slack Channels
# =====================================================
SLACK_CRITICAL_CHANNEL=#padi-critical
SLACK_ALERT_CHANNEL=#padi-alerts
SLACK_OPS_CHANNEL=#padi-ops
SLACK_DEVOPS_CHANNEL=#padi-devops
SLACK_MAINTENANCE_CHANNEL=#padi-maintenance
SLACK_REPORTS_CHANNEL=#padi-reports
SLACK_ALCHEMY_CHANNEL=#padi-alchemy

# =====================================================
# Email Recipients
# =====================================================
EMAIL_CRITICAL=cto@padi-nairobi-01,critical@padi-nairobi-01
EMAIL_EXECUTOR=nairobi-ops@padi-nairobi-01
EMAIL_WARNING=oncall@padi-nairobi-01
EMAIL_INFRA=devops@padi-nairobi-01
EMAIL_MAINTENANCE=maintenance-team@padi-nairobi-01
EMAIL_INFO=digest@padi-nairobi-01
EMAIL_ALCHEMY=alchemy-alerts@padi-nairobi-01

# =====================================================
# Alert Intervals
# =====================================================
ALERT_REPEAT_INTERVAL_CRITICAL=15m
ALERT_REPEAT_INTERVAL_WARNING=4h

# =====================================================
# External Endpoints
# =====================================================
HEALTHCHECKS_IO_URL=https://nosnch.in/REPLACE-WITH-YOUR-ACTUAL-PROJECT-SLUG
WEBHOOK_CRITICAL_URL=http://localhost:5000/webhook/critical
WEBHOOK_ALERT_URL=http://localhost:5000/webhook/alerts

# =====================================================
# Alchemy Configuration
# =====================================================
ALCHEMY_ENDPOINT=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_NETWORK=mainnet
ALCHEMY_CHAIN_ID=1
ALCHEMY_APP_NAME=peculiars-first-app
ALCHEMY_RPC_TIMEOUT=30000
