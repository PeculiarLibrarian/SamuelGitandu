@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://padi.u/schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =====================================================
# 🏛️ PADI SHACL SHAPE — OPPORTUNITY VALIDATION
# =====================================================

ex:OpportunityShape a sh:NodeShape ;
    sh:targetClass ex:FinancialSignal ;
    rdfs:comment "Validates FinancialSignal and ExecutableFact instances according to the 1003 Rule and infrastructure requirements." ;

    # ---------------------------
    # RULE 1: Confidence MUST be exactly 1.0
    # ---------------------------
    sh:property [
        sh:path ex:hasConfidence ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 1.0 ;
        rdfs:comment "Confidence score must exist exactly once and have a value of 1.0." ;
    ] ;

    # ---------------------------
    # RULE 2: Verification Sources MUST be exactly 3
    # ---------------------------
    sh:property [
        sh:path ex:hasVerificationSource ;
        sh:datatype xsd:string ;
        sh:minCount 3 ;
        sh:maxCount 3 ;
        rdfs:comment "Exactly 3 independent verification sources are required (1003 Rule)." ;
    ] ;

    # ---------------------------
    # TARGETING PROPERTIES
    # ---------------------------
    sh:property [
        sh:path ex:hasTargetAddress ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        rdfs:comment "The contract or wallet address targeted by this signal; single occurrence." ;
    ] ;

    sh:property [
        sh:path ex:hasActionType ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        rdfs:comment "The specific action type (e.g., SWAP, ARB, AUDIT); single occurrence." ;
    ] ;

    # ---------------------------
    # IDENTITY & TRACEABILITY
    # ---------------------------
    sh:property [
        sh:path ex:hasSignalID ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        rdfs:comment "Unique deterministic identifier (SHA256 or similar); single occurrence." ;
    ] ;

    sh:property [
        sh:path ex:observedAt ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        rdfs:comment "Timestamp when the signal was observed; single occurrence, ideally UTC." ;
    ] ;

    # ---------------------------
    # INFRASTRUCTURE CONTEXT
    # ---------------------------
    sh:property [
        sh:path ex:atBlockNumber ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        rdfs:comment "The blockchain/mempool block number where the signal was observed." ;
    ] ;

    sh:property [
        sh:path ex:hasGasPriceGwei ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        rdfs:comment "Gas price at time of observation in Gwei; single occurrence." ;
    ] ;

    sh:property [
        sh:path ex:isValidated ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        rdfs:comment "Indicates whether the signal passed validation (true/false)." ;
    ] .
