@prefix ex: <http://padi.u/schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =====================================================
# 🏛️ PADI LEXICON — PRODUCTION ONTOLOGY
# =====================================================

# ---------------------------
# CLASSES
# ---------------------------

# A detected signal from mempool / on-chain / external data
ex:FinancialSignal rdf:type owl:Class ;
    rdfs:label "Financial Signal" .

# A validated, deterministic signal ready for execution
ex:ExecutableFact rdf:type owl:Class ;
    rdfs:subClassOf ex:FinancialSignal ;
    rdfs:label "Executable Fact" .

# ---------------------------
# CORE PROPERTIES (1003 RULE)
# ---------------------------

# Confidence score — must be exactly 1.0 (enforced via SHACL)
ex:hasConfidence rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:FinancialSignal ;
    rdfs:range xsd:decimal ;
    rdfs:label "Confidence Score" .

# Verification sources — must be exactly 3 independent sources (SHACL enforced)
ex:hasVerificationSource rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:FinancialSignal ;
    rdfs:range xsd:string ;
    rdfs:label "Verification Source" .

# ---------------------------
# IDENTITY & TRACEABILITY
# ---------------------------

# Deterministic unique identifier (e.g., SHA256 hash)
ex:hasSignalID rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:FinancialSignal ;
    rdfs:range xsd:string ;
    rdfs:label "Signal Identifier" .

# Timestamp of when the signal was observed
ex:observedAt rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:FinancialSignal ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Observed Timestamp" .

# ---------------------------
# VALIDATION STATE
# ---------------------------

# Indicates whether the signal passed validation (true/false)
ex:isValidated rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:FinancialSignal ;
    rdfs:range xsd:boolean ;
    rdfs:label "Validation Status" .

# ---------------------------
# INFRASTRUCTURE CONTEXT (BASE L2)
# ---------------------------

# Block number where the signal was observed
ex:atBlockNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:FinancialSignal ;
    rdfs:range xsd:integer ;
    rdfs:label "Block Number" .

# Gas price at time of observation (in Gwei)
ex:hasGasPriceGwei rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:FinancialSignal ;
    rdfs:range xsd:decimal ;
    rdfs:label "Gas Price (Gwei)" .
