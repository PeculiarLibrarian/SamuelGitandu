@prefix ex: <http://padi.u/schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# =====================================================
# 🏛️ PADI CLASSES & PROPERTIES
# Multi-Network Definitions | Nairobi-01 Node
# =====================================================

# ─────────────────────────────────────────────────────────────────────
# RDF CLASSES
# ─────────────────────────────────────────────────────────────────────

ex:FinancialSignal a rdfs:Class ;
    rdfs:label "Financial Signal" ;
    rdfs:comment "A financial signal detected on blockchain networks (OP Mainnet or Ethereum Mainnet)." .

ex:ExecutableFact a rdfs:Class ;
    rdfs:label "Executable Fact" ;
    rdfs:comment "An executable fact derived from a verified financial signal." .

# ─────────────────────────────────────────────────────────────────────
# CORE PROPERTIES
# ─────────────────────────────────────────────────────────────────────

ex:hasConfidence a rdfs:Property ;
    rdfs:label "Confidence Score" ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Confidence score for the signal (0.0 - 1.0). Must be 1.0 for 1003 Rule." .

ex:hasVerificationSource a rdfs:Property ;
    rdfs:label "Verification Source" ;
    rdfs:range xsd:string ;
    rdfs:comment "Independent verification sources for the signal. Exactly 3 required (1003 Rule)." .

ex:hasTargetAddress a rdfs:Property ;
    rdfs:label "Target Address" ;
    rdfs:range xsd:string ;
    rdfs:comment "Contract or wallet address targeted by this signal." .

ex:hasActionType a rdfs:Property ;
    rdfs:label "Action Type" ;
    rdfs:range xsd:string ;
    rdfs:comment "Action type of this signal (e.g., SWAP, ARB, AUDIT)." .

ex:hasSignalID a rdfs:Property ;
    rdfs:label "Signal ID" ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique deterministic identifier for the signal (e.g., SHA256 hash)." .

ex:observedAt a rdfs:Property ;
    rdfs:label "Observation Timestamp" ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Timestamp when the signal was observed (UTC)." .

# ─────────────────────────────────────────────────────────────────────
# NETWORK CONTEXT PROPERTIES
# ─────────────────────────────────────────────────────────────────────

ex:hasNetworkType a rdfs:Property ;
    rdfs:label "Network Type" ;
    rdfs:range xsd:string ;
    rdfs:comment "Network type: 'op-mainnet', 'op-sepolia', 'eth-mainnet', 'eth-sepolia'." .

ex:hasChainID a rdfs:Property ;
    rdfs:label "Chain ID" ;
    rdfs:range xsd:integer ;
    rdfs:comment "EVM chain ID (10 for OP Mainnet, 1 for Ethereum Mainnet)." .

ex:hasSourceProvider a rdfs:Property ;
    rdfs:label "Source Provider" ;
    rdfs:range xsd:string ;
    rdfs:comment "API provider that supplied the signal (e.g., 'Alchemy-OP-Mainnet')." .

# ─────────────────────────────────────────────────────────────────────
# VERIFICATION METADATA PROPERTIES
# ─────────────────────────────────────────────────────────────────────

ex:hasVerificationConfidence a rdfs:Property ;
    rdfs:label "Verification Confidence" ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Confidence score for each verification source (0.0 - 1.0)." .

ex:hasVerificationTimestamp a rdfs:Property ;
    rdfs:label "Verification Timestamp" ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Timestamp when each verification source confirmed the signal." .

ex:hasVerificationMatch a rdfs:Property ;
    rdfs:Label "Verification Match" ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether the verification source matches the primary signal." .

# ─────────────────────────────────────────────────────────────────────
# CROSS-NETWORK VERIFICATION PROPERTIES
# ─────────────────────────────────────────────────────────────────────

ex:hasPrimaryNetwork a rdfs:Property ;
    rdfs:label "Primary Network" ;
    rdfs:range xsd:string ;
    rdfs:comment "Primary network where signal was first observed." .

ex:hasFallbackNetwork a rdfs:Property ;
    rdfs:label "Fallback Network" ;
    rdfs:range xsd:string ;
    rdfs:comment "Fallback network used for verification." .

ex:hasCrossNetworkVerification a rdfs:Property ;
    rdfs:Label "Cross-Network Verification" ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether the signal was verified across networks." .

# ─────────────────────────────────────────────────────────────────────
# INFRASTRUCTURE CONTEXT PROPERTIES
# ─────────────────────────────────────────────────────────────────────

ex:atBlockNumber a rdfs:Property ;
    rdfs:label "Block Number" ;
    rdfs:range xsd:integer ;
    rdfs:comment "The blockchain block number where the signal was observed." .

ex:hasGasPriceGwei a rdfs:Property ;
    rdfs:label "Gas Price" ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Gas price at time of observation in Gwei." .

ex:isValidated a rdfs:Property ;
    rdfs:label "Validation Status" ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Indicates whether the signal passed validation." .
